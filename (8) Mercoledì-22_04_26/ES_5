class Animale: #Classe base con attributi e metodi comuni a tutti gli animali
    def __init__(self, nome, eta): #Costruttore della classe base
        self.nome = nome #Attributo di istanza
        self.eta = eta #pt.2

    def fai_suono(self): #Metodo generico che verrà sovrascritto dalle classi figlie
        print(f"\n{self.nome} fa un suono generico.")


class Leone(Animale): #Eredita tutti gli attributi e metodi di Animale
    def __init__(self, nome, eta, branco):
        super().__init__(nome, eta) #super() richiama il costruttore della classe base
        self.branco = branco #Attributo specifico di Leone

    def fai_suono(self): #Override che sovrascrive fai_suono() della classe base
        print(f"\n{self.nome} ruggisce")

    def caccia(self): #Metodo specifico solo della classe Leone
        print(f"{self.nome} sta cacciando con il suo branco di {self.branco} leoni.")


class Giraffa(Animale):
    def __init__(self, nome, eta, altezza):
        super().__init__(nome, eta) 
        self.altezza = altezza

    def fai_suono(self): 
        print(f"\n{self.nome} non emette alcun suono.")

    def mangia_foglie(self):
        print(f"{self.nome} è alta {self.altezza}m.")


class Pinguino(Animale): 
    def __init__(self, nome, eta, velocita_nuoto):
        super().__init__(nome, eta)
        self.velocita_nuoto = velocita_nuoto
        
    def fai_suono(self): 
        print(f"\n{self.nome} emette un verso strano")

    def nuota(self):
        print(f"{self.nome} nuota a {self.velocita_nuoto} km/h.\n")


#Creo le istanze per tipo con nome età e caratteristiche varie

leone   = Leone("Simba", 5, 4) #nome, età e dimensione branco
giraffa = Giraffa("Manny", 8, 5.5) #nome, età e altezza
pinguino = Pinguino("Pingu", 3, 25) #nome, età e velocità nuoto

#Richiamo i metodi
leone.fai_suono() #metodo sovrascritto di Leone
leone.caccia() #metodo specifico di Leone

giraffa.fai_suono()                                             
giraffa.mangia_foglie()                                         

pinguino.fai_suono()                                             
pinguino.nuota()                                                 
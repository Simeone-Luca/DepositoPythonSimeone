class Animale: #definizione
    numero_animali = 0 #Attributo della classe che viene visto da tutte le istanze

    def __init__(self, nome, specie): #Costruttore che riceve nome e specie come attributi di istanza
        self.nome = nome #Attributo di istanza che è unico per ogni oggetto
        self.specie = specie #Attributo di istanza pt. 2
        Animale.numero_animali += 1 #Incrementa il contatore della classe ad ogni nuova istanza

    @classmethod #Permette al metodo di accedere agli attributi di classe tramite cls
    def quanti_animali(cls): #cls fa riferimento alla classe stessa e non a un'istanza
        print(f"\n Numero di animali creati: {cls.numero_animali} \n") #legge il contatore dalla classe e non da un'istanza

a1 = Animale("Leone", "Felino") #Creazione del primo oggetto che porta numero_animali a diventare 1
a2 = Animale("Falco", "Rapace") #pt.2 numero_animali=2
a3 = Animale("Delfino", "Mammifero") #pt.2 numero_animali=3 (perchè sopra viene incrementato ogni volta)

Animale.quanti_animali()#richiamo la classe per evitare di usare a1 a2 o a3
import random

# Funzioni:
def chiedi_numero_positivo():
# Chiedo il numero positivo, ripete finché non è > di 0
    while True:
        # utilizzo try ed except per garantire la tutela da errori, in modo tale da non inserire troppi check con condizioni etc...
        try:
            n = int(input("Inserisci un numero intero positivo: "))
            if n > 0:
                return n
            else:
                print("Il numero deve essere positivo (> 0). Riprova.")
        except ValueError:
            print("Errore: devi inserire un numero intero. Riprova.")


def genera_lista_casuale(n):
# genera lla lista di numeri casuali tra 1 e n
    return [random.randint(1, n) for _ in range(n)]


def somma_numeri_pari(lista):
# somma dei numeri pari con ciclo for per controllare i numeri pari e stamparli
    somma = 0
    for num in lista:
        if num % 2 == 0:
            somma += num
    print(f"Somma dei numeri pari: {somma}")


def stampa_numeri_dispari(lista):
# stampa di tutti i numeri dispari
    print("Numeri dispari nella lista:", end=" ")
    for num in lista:
        if num % 2 != 0:
            print(num, end=" ")
    print()  # a capo


def is_primo(numero):
# restituisce true se il numero è primo, sennò false
    if numero <= 1:
        return False
    if numero <= 3:
        return True
    if numero % 2 == 0 or numero % 3 == 0:
        return False
    
    # ciclo per check su numero
    i = 5
    while i * i <= numero:
        if numero % i == 0 or numero % (i + 2) == 0:
            return False
        i += 6
    return True


def stampa_numeri_primi(lista):
# stampa tutti i numeri primi della lista
    print("Numeri primi nella lista:", end=" ")
    for num in lista:
        if is_primo(num):
            print(num, end=" ")
    print()


def verifica_somma_prima(lista):
# verifica se la somma di tutti i numeri è un numero primo
    somma_totale = sum(lista)
    if is_primo(somma_totale):
        print(f"La somma totale ({somma_totale}) è un numero primo!")
    else:
        print(f"La somma totale ({somma_totale}) NON è un numero primo.")


#Menu:

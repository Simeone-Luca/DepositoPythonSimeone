                print("Grazie per aver usato questa specie di programma. Arrivederci!")
                break

            case _:
                print("Scelta non valida! Inserisci un numero da 1 a 8.")

# Start del programma
if __name__ == "__main__":
    # Variabili globali per condividere n e la lista tra le funzioni
    numero_n = None
    lista_corrente = None
    menu()
    
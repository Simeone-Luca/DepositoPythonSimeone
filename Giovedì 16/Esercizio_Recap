                n = chiedi_numero_positivo()
                print(f"Numero corretto: {n}")
                # salvo n per usarlo nelle altre funzioni con global, che mi permette di non diventare pazzo, idem cn tutti gli altri valori
                global numero_n
                numero_n = n

            case "2":
                try:
                    lista = genera_lista_casuale(numero_n)
                    print(f"Lista generata: {lista}")
                    # salvo la lista per usarla dopo

s = input("Inserisci numeri separati da spazio: ") # viene presa in input la lista come stringa

if s == "": 
    print("Lista vuota") # condizione per controllare se la lista è vuota altrimenti procede con la dichiarazione e il ciclo for
else:
    num = ""
    max_val = 0
    count = 0
    primo = True

    s = s + " "

    for c in s: # ciclo sugli eleemnti di s
        if c != " ":
            num = num + c # se c è diverso da spazio, num sarà uguale ad esso più c
        else:
            if num != "": # altrimenti se num è diverso da nulla n sarà uguale a l'intero di num
                n = int(num)

                if primo: # se primo è true allora max_val sarà uguale a n e primo diventerà false e count sarà incrementato di 1 e num tornerà vuoto
                    max_val = n
                    primo = False
                else:
                    if n > max_val: # altrimenti se n è maggiore di max_value, esso varrà n
                        max_val = n

                count = count + 1 
                num = ""

    if count == 0: # controllo del conteggio per capire se la lista è vuota
        print("Lista Vuota")
    else: # altrimenti stampa il valore massimo e il numero di elementi in lista
        print("Numero massimo:", max_val)
        print("Numero di elementi:", count)
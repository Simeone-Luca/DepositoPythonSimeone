import math #Importo la funzione sqrt per la radice quadrata

class Punto:
    
    #Metodo che viene richiamato quando creo un nuovo oggetto punto
    def __init__(self, x, y):
        #definisco gli attributi dell'oggetto per rappresentare le coordinate del punto x e y
        self.x = x
        self.y = y

    #Metodo per spostare il punto nel piano
    def muovi(self, dx, dy):
        self.x += dx#aggiunge dx alla coordinata x
        self.y += dy#aggiunge dy alla coordinata y

    #Metodo per calcolare la distanza dall'origine (0,0)
    def distanza_da_origine(self):
        return math.sqrt(self.x**2 + self.y**2)#formula calcolo distanza

#stampa:
p = Punto(3, 4)#creo un punto con coordinate 3,4

print(p.distanza_da_origine())#risultato 5.0

p.muovi(1, -2)#Sposto il punto

print(p.x, p.y)#Nuove coordinate 4,2
print(p.distanza_da_origine())#Nuova distanza dall'origine
class Posto: #definisco la classe base che rappresenta un generico posto nel teatro con attributi privati e metodi comuni
    def __init__(self, numero, fila): #il costruttore riceve numero e fila e inizializza lo stato del posto come libero
        self._numero = numero #uso il prefisso underscore per indicare che l'attributo è privato per convenzione in Python non esiste un vero private come in altri linguaggi
        self._fila = fila #salvo la fila come attributo privato dell'istanza tramite self che rappresenta l'oggetto corrente
        self._occupato = False #inizializzo sempre il posto come libero indipendentemente dal tipo di posto

    def prenota(self): #metodo polimorfico che le sottoclassi potranno sovrascrivere con il loro comportamento specifico
        if not self._occupato: #verifico che il posto non sia già occupato usando not che inverte il valore booleano
            self._occupato = True #imposto lo stato a True per segnare il posto come occupato
            print(f"Posto {self._numero} fila {self._fila} prenotato con successo")
        else: #entro in questo ramo se il posto era già occupato
            print(f"Posto {self._numero} fila {self._fila} è già occupato")

    def libera(self): #metodo per liberare un posto precedentemente prenotato
        if self._occupato: #controllo che il posto sia effettivamente occupato prima di liberarlo
            self._occupato = False #rimetto lo stato a False per rendere il posto nuovamente disponibile
            print(f"Posto {self._numero} fila {self._fila} liberato con successo")
        else: #se il posto non era occupato segnalo la situazione
            print(f"Posto {self._numero} fila {self._fila} non era prenotato")

    @property #uso il decorator property per creare un getter che permette di accedere all'attributo privato come se fosse pubblico senza parentesi nella chiamata
    def numero(self): #getter per recuperare il numero del posto
        return self._numero #restituisco il valore dell'attributo privato al chiamante

    @property #decorator property applicato anche al getter della fila per uniformità nell'interfaccia della classe
    def fila(self): #getter per recuperare la fila del posto
        return self._fila #restituisco il valore dell'attributo privato _fila

    @property #terzo getter per lo stato di occupazione del posto
    def occupato(self): #getter che restituisce il booleano che indica se il posto è occupato o libero
        return self._occupato #restituisco _occupato che è True se prenotato e False se libero

    @property #getter aggiuntivo che traduce il booleano in una stringa leggibile per la stampa
    def stato(self): #restituisce una descrizione testuale dello stato invece del booleano grezzo
        return "occupato" if self._occupato else "libero" #uso l'espressione ternaria inline che in Python si scrive come valore_se_vero if condizione else valore_se_falso


class PostoVIP(Posto): #eredito da Posto per aggiungere funzionalità specifiche dei posti VIP mantenendo l'interfaccia comune
    def __init__(self, numero, fila, servizi_extra=None): #il parametro servizi_extra ha None come valore di default per rendere l'argomento opzionale
        super().__init__(numero, fila) #chiamo il costruttore della classe base tramite super() per inizializzare numero fila e occupato senza ripetere codice
        self._servizi_extra = servizi_extra if servizi_extra is not None else [] #uso l'espressione condizionale per assegnare la lista passata oppure una lista vuota evitando il problema del mutable default argument

    def prenota(self): #sovrascrivo il metodo polimorfico per aggiungere la logica specifica dei posti VIP oltre alla prenotazione base
        if not self._occupato: #ricontrollo lo stato perché non posso chiamare super().prenota() e poi aggiungere logica dato che prenota() cambia stato
            self._occupato = True #imposto il posto come occupato replicando la logica base perché devo gestire l'output in modo personalizzato
            print(f"Posto VIP {self._numero} fila {self._fila} prenotato con successo")
            print(f"Servizi attivati per il posto VIP:") #stampo l'elenco dei servizi extra attivati con la prenotazione VIP
            for servizio in self._servizi_extra: #itero sulla lista dei servizi extra con un ciclo for che estrae un elemento alla volta
                print(f"  - {servizio}") #stampo ogni servizio con indentazione visiva per chiarezza
        else: #gestisco il caso in cui il posto VIP fosse già prenotato
            print(f"Posto VIP {self._numero} fila {self._fila} è già occupato")

    @property #getter specifico per i servizi extra del posto VIP non presente nella classe base
    def servizi_extra(self): #restituisce la lista dei servizi attivabili con la prenotazione VIP
        return self._servizi_extra #restituisco la lista privata tramite il getter per rispettare l'incapsulamento


class PostoStandard(Posto): #eredito da Posto per aggiungere il costo di prenotazione tipico dei posti standard con acquisto online
    def __init__(self, numero, fila, costo=0.0): #il costo ha 0.0 come valore di default per renderlo opzionale mantenendo il tipo float
        super().__init__(numero, fila) #delego l'inizializzazione degli attributi comuni alla classe base tramite super()
        self._costo = costo #salvo il costo come attributo privato dell'istanza del posto standard

    def prenota(self): #sovrascrivo prenota() per mostrare il cisto della prenotazione online prima di completarla
        if not self._occupato: #verifico la disponibilità prima di procedere con la prenotazione
            self._occupato = True #aggiorno lo stato a occupato
            print(f"Posto Standard {self._numero} fila {self._fila} prenotato con successo")
            print(f"Costo prenotazione online: {self._costo:.2f} euro") #mostro il costo con due decimali usando il format specifier :.2f che arrotonda a due cifre dopo la virgola
        else: #caso in cui il posto standard fosse già prenotato da qualcun altro
            print(f"Posto Standard {self._numero} fila {self._fila} è già occupato")

    @property #getter per accedere al costo del posto standard dall'esterno senza modificarlo direttamente
    def costo(self): #restituisce il costo della prenotazione online del posto standard
        return self._costo #restituisco il valore privato _costo tramite il getter


class Teatro: #definisco il gestore del teatro che contiene tutti i posti e fornisce le operazioni di gestione
    def __init__(self): #il costruttore inizializza il teatro con una lista vuota pronta a ricevere i posti
        self._posti = [] #uso una lista vuota come struttura dati per contenere tutti gli oggetti Posto VIP e Standard

    def aggiungi_posto(self, posto): #metodo per aggiungere un posto alla lista del teatro accettando qualsiasi sottoclasse di Posto
        self._posti.append(posto) #append() è il metodo delle liste Python che aggiunge un elemento in fondo alla lista in O(1)

    def prenota_posto(self, numero, fila): #metodo che cerca un posto per numero e fila e se lo trova invoca prenota() su di esso
        for posto in self._posti: #itero su tutti i posti nella lista cercando quello corrispondente ai parametri ricevuti
            if posto.numero == numero and posto.fila == fila: #confronto numero e fila usando i getter definiti nella classe base con and che richiede entrambe le condizioni ver
                posto.prenota() #invoco il metodo polimorfico sul posto trovato Python eseguirà automaticamente la versione corretta in base al tipo reale dell'oggetto
                return #uso return per uscire subito dal metodo dopo aver trovato e prenotato il posto evitando iterazioni inutili
        print(f"Posto {numero} fila {fila} non trovato nel teatro") #raggiungo questa riga solo se nessun posto corrisponde ai criteri cercati

    def libera_posto(self, numero, fila): #metodo aggiuntivo per liberare un posto cercandolo per numero e fila
        for posto in self._posti: #itero sulla lista cercando il posto da liberare
            if posto.numero == numero and posto.fila == fila: #verifico la corrispondenza di entrambi i campi identificativi del posto
                posto.libera() #chiamo libera() sul posto trovato che è un metodo della classe base non sovrascrivibile
                return #esco subito dopo aver trovato il posto per evitare iterazioni inutili
        print(f"Posto {numero} fila {fila} non trovato nel teatro") #messaggio di errore se il posto cercato non esiste

    def stampa_posti_occupati(self): #metodo per visualizzare lo stato attuale del teatro mostrando solo i posti prenotati
        occupati = [p for p in self._posti if p.occupato] #uso una list comprehension per filtrare la lista originsle creando una nuova lista con solo i posti occupati la sintassi è [espressione for elemento in iterabile if condizione]
        if not occupati: #controllo se la lista filtrata è vuota dato che una lista vuota è falsy in Python
            print("Nessun posto occupato al momento")
        else: #se ci sono posti occupati li stampo tutti con i loro dettagli
            print("Posti attualmente occupati:")
            for posto in occupati: #itero sulla lista filtrata dei posti occupati
                tipo = type(posto).__name__ #recupero il nome della classe reale dell'oggetto tramite type() e __name__ per distinguere VIP da Standard nell'output
                print(f"  Posto {posto.numero} - Fila {posto.fila} - Tipo: {tipo}") #stampo i dettagli del posto occupato con indentazione per leggibilità

    def stampa_tutti_posti(self): #metodo di utilità per mostrare tutti i posti con il loro stato attuale utile per orientarsi nel menu
        print("Stato completo del teatro:")
        for posto in self._posti: #itero su tutta la lista dei posti senza filtri
            tipo = type(posto).__name__ #ricavo il nome del tipo reale per distinguere visivamente VIP e Standard
            print(f"  Posto {posto.numero} - Fila {posto.fila} - Tipo: {tipo} - Stato: {posto.stato}") #mostro tutti i dettagli incluso lo stato tramite il getter che restituisce la stringa leggibile


def inizializza_teatro(): #definisco una funzione separata per costruire il teatro con i posti iniziali separando la logica di setup dal loop principale
    teatro = Teatro() #creo l'istanza del teatro che conterrà tutti i posti

    teatro.aggiungi_posto(PostoVIP(1, "A", ["Accesso al lounge", "Servizio in posto", "Bevande incluse"])) #aggiungo il primo posto VIP con la sua lista di servizi extra passata direttamente al costruttore
    teatro.aggiungi_posto(PostoVIP(2, "A", ["Accesso al lounge", "Parcheggio riservato"])) 
    teatro.aggiungi_posto(PostoVIP(3, "A", ["Accesso al lounge", "Servizio in posto"])) 

    teatro.aggiungi_posto(PostoStandard(1, "B", 15.50)) #aggiungo il primo posto standard in fila B con il suo costo di prenotazione online
    teatro.aggiungi_posto(PostoStandard(2, "B", 15.50)) 
    teatro.aggiungi_posto(PostoStandard(3, "B", 15.50)) 

    teatro.aggiungi_posto(PostoStandard(1, "C", 12.00)) #posti in fila C con costo leggermente inferiore
    teatro.aggiungi_posto(PostoStandard(2, "C", 12.00)) 
    teatro.aggiungi_posto(PostoStandard(3, "C", 12.00)) 

    return teatro #restituisco il teatro già configurato alla funzione chiamante


def menu_principale(teatro): #definisco la funzione che gestisce il menu interattivo ricevendo il teatro come parametro per operare su di esso
    print("\n--- Menù di LS Teatrapp - Il sistema per prenotare i tuoi spettacoli preferiti! ---")
    print("1 - Visualizza tutti i posti")
    print("2 - Prenota un posto")
    print("3 - Libera un posto")
    print("4 - Visualizza posti occupati")
    print("5 - Torna al menu principale")

    scelta = input("Scegli un'opzione: ").strip() #leggo la scelta e uso strip() per rimuovere spazi bianchi e newline accidentali prima e dopo la stringa

    try:
            scelta = int(scelta)
    except:
        print("\nOpzione non valida!")
    
    match scelta:
        case 1: #visualizzazione completa dei posti
            teatro.stampa_tutti_posti() #chiamo il metpdo del teatro che mostra tutti i posti con il loro stato

        case 2: #prenotazione di un posto
            teatro.stampa_tutti_posti() #mostro prima i posti disponibili per aiutare l'utente nella scelta
            try: #uso try/except per gestire l'eccezione ValueError che si genera se l'utente inserisce un non numero
                numero = int(input("Numero del posto: ")) #converto subito a intero perché i numeri dei posti sono definiti come int nel costruttore
                fila = input("Fila del posto (es. A B C): ").strip().upper() #strip() rimuove spazi e upper() converte in maiuscolo per uniformità con i dati del teatro
                teatro.prenota_posto(numero, fila) #chiamo il metodo del teatro che trova il posto e invoca prenota() su di esso
            except ValueError: #catturo l'eccezione se l'utente inserisce lettere invece di un numero
                print("Numero non valido inserisci un intero")

        case 3: #liberare un posto prenotato
            teatro.stampa_posti_occupati() #mostro prima i posti occupati per orientare l'utente
            try: #gestisco errore di conversione a intero
                numero = int(input("Numero del posto da liberare: ")) #leggo e converto il numero del posto
                fila = input("Fila del posto da liberare: ").strip().upper() #leggo la fila normalizzandola in maiuscolo
                teatro.libera_posto(numero, fila) #chiamo il metodo del teatro per liberare il posto trovato
            except ValueError: #gestisco l'inserimento non valido
                print("Numero non valido inserisci un intero")

        case 4: #bisualizzare solo i posti occupati
            teatro.stampa_posti_occupati() #chiamo il metodo che filtra e stampa solo i posti con stato occupato

        case 5: #menu principale del loop while esterno
            pass 

        case _: #gestisco qualsiasi altro input non previstp
            print("Devi scegliere un numero tra 1 e 5. Mannaggia a te!")


if __name__ == "__main__": #il codice dentro questo blocco viene eseguito solo se il file è avviato direttamente e non importato come modulo
    print("Benvenuto al sistema di gestione del teatro")
    teatro = inizializza_teatro() #inizializzo il teatro una sola volta prima del loop così lo stato persiste tra un'iterazione e l'altra

    while True: #ciclo infinito che simula il comportamento di un'applicazione sempre aperta finché l'utente non sceglie di uscire
        risposta = input("\nVuoi prenotare o gestire il teatro? (si/no): ").strip().lower() #strip() rimuove spazi e lower() converte tutto in minuscolo per confrontare senza problemi di maiuscole

        match risposta:
            case "no": #l'unica condizione di uscita dal loop infinito
                print("Arrivederci e grazie per aver usato LS Teatrapp")
                break

            case "si": #accesso alle funzioni di gestione del teatro
                continua_gestione = True #flag booleano che controlla il loop interno del menu
                
                while continua_gestione: #loop interno per permettere più operazioni consecutive senza tornare al menu principale
                    menu_principale(teatro) #chiamo la funzione del menu che gestisce una singola operazione alla volta
                    ancora = input("\nVuoi continuare con un'altra operazione? (si/no): ").strip().lower() #chiedo se l'utente vuole fare un'altra operazione
                    if ancora == "no": #se l'utente non vuole continuare esco dal loop interno
                        continua_gestione = False #imposto il flag a False per far terminare il while interno al prossimo controllo della condizione

            case _: #gestisco input non validi
                print("Risposta non valida inserisci si o no")
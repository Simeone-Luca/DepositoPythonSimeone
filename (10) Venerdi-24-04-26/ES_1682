class ContoBancario: #definisco la classe che rappresenta un conto bancario e uso l incapsulamento per proteggere i dati

    def __init__(self, titolare, saldo_iniziale=0.0): #inizializzo l oggetto e assegno valori iniziali agli attributi privati
        if isinstance(titolare, str) and titolare.strip() != "": #controllo che il titolare sia una stringa non vuota usando isinstance e strip
            self.__titolare = titolare #assegno il titolare all attributo privato usando il name mangling con doppio underscore
        else:
            print("titolare non valido") #gestisco errore senza usare eccezioni
            self.__titolare = "sconosciuto" #assegno un valore di fallback per garantire consistenza
        
        if isinstance(saldo_iniziale, (int, float)) and saldo_iniziale >= 0: #controllo che il saldo sia numerico e non negativo
            self.__saldo = float(saldo_iniziale) #converto in float per uniformita di gestione dei decimali
        else:
            print("saldo iniziale non valido") #se non valido informo l utente
            self.__saldo = 0.0 #imposto saldo a zero per sicurezza

    def deposita(self, importo): #metodo pubblico per aumentare il saldo
        if isinstance(importo, (int, float)) and importo > 0: #verifico che l importo sia numerico e positivo
            self.__saldo += importo #aggiorno il saldo accedendo all attributo privato internamente
        else:
            print("importo deposito non valido") #impedisco operazioni non corrette

    def preleva(self, importo): #metodo pubblico per diminuire il saldo
        if not isinstance(importo, (int, float)) or importo <= 0: #controllo validita importo
            print("importo prelievo non valido") #blocco input non valido
        elif importo > self.__saldo: #verifico disponibilita fondi confrontando con saldo privato
            print("fondi insufficienti") #impedisco saldo negativo
        else:
            self.__saldo -= importo #aggiorno saldo solo se tutte le condizioni sono rispettate

    def visualizza_saldo(self): #metodo di sola lettura per il saldo
        return self.__saldo #restituisco il valore senza permettere modifica diretta dall esterno

    def get_titolare(self): #getter per accedere al titolare in modo controllato
        return self.__titolare #ritorno il valore privato mantenendo incapsulamento

    def set_titolare(self, nuovo_titolare): #setter per modificare il titolare con validazione
        if isinstance(nuovo_titolare, str) and nuovo_titolare.strip() != "": #verifico che sia stringa valida
            self.__titolare = nuovo_titolare #aggiorno attributo privato
        else:
            print("nuovo titolare non valido") #evito modifiche scorrette
            
            
conto = ContoBancario("Jannik Sinner", 10000000.0) #creo un oggetto della classe e inizializzo titolare e saldo iniziale

print("\ntitolare:", conto.get_titolare()) #uso il getter per leggere il titolare senza accedere direttamente all attributo privato
print("\nsaldo iniziale:", conto.visualizza_saldo()) #uso il metodo pubblico per leggere il saldo in modo sicuro

conto.deposita(50) #chiamo il metodo deposita e aumento il saldo se l importo e valido
print("\nsaldo dopo deposito:", conto.visualizza_saldo()) #verifico il nuovo saldo aggiornato

conto.preleva(30) #chiamo il metodo preleva e riduco il saldo se ci sono fondi sufficienti
print("\nsaldo dopo prelievo:", conto.visualizza_saldo()) #controllo il saldo dopo l operazione

conto.preleva(200) #provo a prelevare piu del saldo disponibile per testare il controllo dei fondi
print("\nsaldo dopo tentativo errato:", conto.visualizza_saldo()) #verifico che il saldo non sia cambiato

conto.deposita(-10) #provo a depositare un importo non valido per testare la validazione
print("\nsaldo dopo deposito errato:", conto.visualizza_saldo()) #controllo che il saldo resti invariato

conto.set_titolare("Luca Simeone") #uso il setter per aggiornare il titolare con un valore valido
print("\nnuovo titolare:", conto.get_titolare()) #verifico la modifica tramite getter

conto.set_titolare("") #provo a impostare un titolare non valido per testare il controllo
print("\ntitolare dopo tentativo errato:", conto.get_titolare(),"\n") #verifico che il valore non sia cambiato
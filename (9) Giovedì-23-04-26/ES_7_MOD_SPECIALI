class UnitaMilitare:
    def __init__(self, nome, numero_soldati): #definisco il costruttore per inizializzare nome e numero di soldati
        self.nome = nome #assegno il nome dell unita all attributo interno
        self.numero_soldati = numero_soldati #assegno il numero di soldati all attributo interno

    def muovi(self): #definisco il metodo per simulare il movimento
        print(f"{self.nome} si sta muovendo") #stampo un messaggio usando f string per inserire il nome

    def attacca(self): #definisco il metodo per simulare un attacco
        print(f"{self.nome} attacca il nemico") #stampo un messaggio descrittivo

    def ritira(self): #definisco il metodo per il ritiro strategico
        print(f"{self.nome} si ritira strategicamente") #stampo il comportamento di ritirata

    def __str__(self): #ridefinisco str per una rappresentazione leggibile
        return f"Unita {self.nome} con {self.numero_soldati} soldati" #restituisco una stringa semplice per l utente

    def __repr__(self): #ridefinisco repr per una rappresentazione piu tecnica
        return f"UnitaMilitare(nome={self.nome}, soldati={self.numero_soldati})" #mostro i dati utili per debugging

    def __len__(self): #ridefinisco len per usare la lunghezza sull oggetto
        return self.numero_soldati #restituisco il numero di soldati come lunghezza

    def __eq__(self, other): #ridefinisco eq per confrontare due oggetti
        return self.nome == other.nome and self.numero_soldati == other.numero_soldati #confronto attributi principali

    def __getattribute__(self, name): #intercetto ogni accesso agli attributi
        print(f"Sto accedendo a {name}") #stampo quale attributo viene richiesto
        return object.__getattribute__(self, name) #uso la versione base per evitare ricorsione infinita


class Fanteria(UnitaMilitare): #eredito dalla classe base
    def costruisci_trincea(self): #metodo specifico fanteria
        print(f"{self.nome} costruisce una trincea") #azione difensiva


class Artiglieria(UnitaMilitare): #eredito dalla classe base
    def calibra_artiglieria(self): #metodo specifico artiglieria
        print(f"{self.nome} calibra i cannoni") #simulo calibrazione


class Cavalleria(UnitaMilitare): #eredito dalla classe base
    def esplora_terreno(self): #metodo specifico cavalleria
        print(f"{self.nome} esplora il terreno") #simulo esplorazione


class SupportoLogistico(UnitaMilitare): #eredito dalla classe base
    def rifornisci_unita(self): #metodo logistico
        print(f"{self.nome} rifornisce le unita") #simulo rifornimento


class Ricognizione(UnitaMilitare): #eredito dalla classe base
    def conduci_ricognizione(self): #metodo di ricognizione
        print(f"{self.nome} conduce ricognizione") #simulo sorveglianza


class ControlloMilitare(Fanteria, Artiglieria, Cavalleria, SupportoLogistico, Ricognizione): #eredito da tutte le classi
    def __init__(self, nome, numero_soldati): #costruttore della classe multipla
        super().__init__(nome, numero_soldati) #richiamo il costruttore della classe base tramite mro
        self.unita_registrate = {} #creo un dizionario per salvare le unita usando nome come chiave

    def registra_unita(self, unita): #metodo per aggiungere unita
        self.unita_registrate[unita.nome] = unita #salvo l oggetto nel dizionario usando il nome come chiave

    def mostra_unita(self): #metodo per stampare tutte le unita
        for nome in self.unita_registrate: #itero su tutte le chiavi del dizionario
            print(self.unita_registrate[nome]) #uso str per stampare ogni unita

    def dettagli_unita(self, nome): #metodo per ottenere dettagli specifici
        if nome in self.unita_registrate: #controllo se l unita esiste
            print(repr(self.unita_registrate[nome])) #uso repr per mostrare dettagli tecnici
        else: #caso in cui non esiste
            print("Unita non trovata") #messaggio di errore


#Esempio di utilizzo
u1 = Fanteria("Alfa", 100) #creo una unita fanteria
u2 = Artiglieria("Bravo", 50) #creo una unita artiglieria

controllo = ControlloMilitare("HQ", 10) #creo il controllo centrale

controllo.registra_unita(u1) #registro la prima unita
controllo.registra_unita(u2) #registro la seconda unita

controllo.mostra_unita() #mostro tutte le unita

controllo.dettagli_unita("Alfa") #mostro dettagli di una unita

print(len(u1)) #uso len per ottenere numero soldati

print(u1 == u2) #confronto due unita